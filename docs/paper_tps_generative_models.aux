\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Basin-resolved structural ensemble from TPS+OPES.} Representative last-frame structures from the four metastable basins identified in the 2D free-energy landscape (Fig.\nobreakspace  {}\ref  {fig:opes2d}). \textbf  {Columns} (left to right): B$_0$ (native pose, $s_1\approx 0.07$\nobreakspace  {}\r A, $s_2\approx 5.37$\nobreakspace  {}\r A); B$_1$ (intermediate, $s_1\approx 0.35$\nobreakspace  {}\r A, $s_2\approx 5.47$\nobreakspace  {}\r A); B$_2$ (displaced, $s_1\approx 0.75$\nobreakspace  {}\r A, $s_2\approx 5.56$\nobreakspace  {}\r A); B$_3$ (far-tail, $s_1\approx 1.10$\nobreakspace  {}\r A, $s_2\approx 5.48$\nobreakspace  {}\r A). \textbf  {Rows}: three representative MC snapshots per basin, chosen to span the basin interior from the centroid outward. Structures are rendered as C$\alpha $ cartoon ribbons with ligand sticks; protein chain coloring is preserved across all panels. }}{4}{figure.1}\protected@file@percent }
\newlabel{fig:structures}{{1}{4}{\textbf {Basin-resolved structural ensemble from TPS+OPES.} Representative last-frame structures from the four metastable basins identified in the 2D free-energy landscape (Fig.~\ref {fig:opes2d}). \textbf {Columns} (left to right): B$_0$ (native pose, $s_1\approx 0.07$~\AA , $s_2\approx 5.37$~\AA ); B$_1$ (intermediate, $s_1\approx 0.35$~\AA , $s_2\approx 5.47$~\AA ); B$_2$ (displaced, $s_1\approx 0.75$~\AA , $s_2\approx 5.56$~\AA ); B$_3$ (far-tail, $s_1\approx 1.10$~\AA , $s_2\approx 5.48$~\AA ). \textbf {Rows}: three representative MC snapshots per basin, chosen to span the basin interior from the centroid outward. Structures are rendered as C$\alpha $ cartoon ribbons with ligand sticks; protein chain coloring is preserved across all panels}{figure.1}{}}
