\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {OPES-TPS 2D free-energy landscape in ligand pose space.} \textit  {Left}: renormalized OPES kernel mixture $P_n(s_1, s_2)$ showing the distribution of adaptive bias kernels; the orange circles mark kernel centroids. \textit  {Middle}: reweighted free-energy proxy $-\qopname  \relax o{ln}(\hat  \rho /\hat  \rho _{\qopname  \relax m{max}})$ as a function of ligand RMSD and ligand--pocket distance. The primary basin near $(s_1, s_2) \approx (0.07\,\text  {\r A},\, 5.37\,\text  {\r A})$ corresponds to the native-like pose; secondary basins at $s_1 \approx 0.70$--$0.83$\nobreakspace  {}\r A{} mark distinct metastable configurations. \textit  {Right}: hexagonal-bin histogram of the TPS+OPES chain's visited $(s_1, s_2)$ values, with OPES contours overlaid. Run parameters: $\gamma = 10$, barrier $= 5\,k_BT$, $N_{\mathrm  {MC}} = 11{,}590$, $N_{\mathrm  {acc}} = 3{,}184$ (acceptance rate $27.5\%$). }}{5}{figure.2}\protected@file@percent }
\newlabel{fig:opes2d}{{2}{5}{\textbf {OPES-TPS 2D free-energy landscape in ligand pose space.} \textit {Left}: renormalized OPES kernel mixture $P_n(s_1, s_2)$ showing the distribution of adaptive bias kernels; the orange circles mark kernel centroids. \textit {Middle}: reweighted free-energy proxy $-\ln (\hat \rho /\hat \rho _{\max })$ as a function of ligand RMSD and ligand--pocket distance. The primary basin near $(s_1, s_2) \approx (0.07\,\text {\AA },\, 5.37\,\text {\AA })$ corresponds to the native-like pose; secondary basins at $s_1 \approx 0.70$--$0.83$~\AA {} mark distinct metastable configurations. \textit {Right}: hexagonal-bin histogram of the TPS+OPES chain's visited $(s_1, s_2)$ values, with OPES contours overlaid. Run parameters: $\gamma = 10$, barrier $= 5\,k_BT$, $N_{\mathrm {MC}} = 11{,}590$, $N_{\mathrm {acc}} = 3{,}184$ (acceptance rate $27.5\%$)}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Structural and energetic distributions of the TPS ensemble.} (a) C$\alpha $ RMSD values of each accepted checkpoint structure relative to the first TPS-accepted structure, for 10 structures sampled at MC steps 10--100. The distribution is narrow ($0.48$--$0.69$\nobreakspace  {}\r A, mean $0.59 \pm 0.06$\nobreakspace  {}\r A), indicating strong structural convergence across distinct denoising trajectories. (b) Total potential energy (kJ/mol) evaluated by OpenMM energy minimization for each TPS checkpoint structure. All structures fall in the range $-42{,}201$ to $-41{,}653$\nobreakspace  {}kJ/mol with a spread of $\approx 548$\nobreakspace  {}kJ/mol, confirming that TPS-sampled structures are physically reasonable across the ensemble. }}{5}{figure.3}\protected@file@percent }
\newlabel{fig:distributions}{{3}{5}{\textbf {Structural and energetic distributions of the TPS ensemble.} (a) C$\alpha $ RMSD values of each accepted checkpoint structure relative to the first TPS-accepted structure, for 10 structures sampled at MC steps 10--100. The distribution is narrow ($0.48$--$0.69$~\AA , mean $0.59 \pm 0.06$~\AA ), indicating strong structural convergence across distinct denoising trajectories. (b) Total potential energy (kJ/mol) evaluated by OpenMM energy minimization for each TPS checkpoint structure. All structures fall in the range $-42{,}201$ to $-41{,}653$~kJ/mol with a spread of $\approx 548$~kJ/mol, confirming that TPS-sampled structures are physically reasonable across the ensemble}{figure.3}{}}
