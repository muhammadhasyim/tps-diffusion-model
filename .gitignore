# ── Python bytecode & caches ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

opes*case2/
muhammad*/
openmm-plumed*
# plumed2/ is a tracked git submodule (PLUMED v2.9.x + OPES overlay build).

# ── Python packaging / build artifacts ────────────────────────────────────────
*.egg-info/
*.egg
dist/
build/
.eggs/
pip-wheel-metadata/
MANIFEST
*.whl

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
.conda/
conda-env/

# ── Type checkers & linters ───────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# ── Testing & coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# ── Jupyter ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── C / C++ / CUDA build artifacts ────────────────────────────────────────────
*.o
*.so
*.a
*.lib
*.dll
*.dylib
*.out
*.mod
*.ptx
# PyTorch checkpoints (often multi-GB — GitHub max file size ~100 MiB via normal git push)
*.pt
*.pth
*.ckpt
*.fatbin
*.cubin
CMakeCache.txt
CMakeFiles/

