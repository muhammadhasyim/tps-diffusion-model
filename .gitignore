*.aux
*.log
*.out
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex.gz
*.bbl
*.blg

# ── OS / editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ── Large local datasets (Runs N' Poses / Zenodo) ─────────────────────────────
data/runs_n_poses/*
!data/runs_n_poses/README.md

# Vendored Runs-N-Poses batch driver: local Foldseek / PLINDER outputs (see docs/runs_n_poses_reproduction.md)
third_party/runs_n_poses/scoring/

# ── Local model weights (layout in git via .gitkeep; blobs stay untracked — no LFS)
# See weights/README.md
weights/boltz/*
!weights/boltz/.gitkeep
weights/finetuned/*
!weights/finetuned/.gitkeep

# ── Secrets / credentials ─────────────────────────────────────────────────────
.env
*.pem
*.key
secrets.json
credentials.json

# ── Local artifacts & experiments (runs, dashboards; symlink outputs → here) ───
artifacts/

# ── Structured outputs symlink convention (see artifacts/evaluation/README_outputs_note.md)
outputs/

/*.log
/*.npz
axon-*.pdf
postprocess.out
opes_tps_run.log
